# Alaz Development Environment

DATABASE_URL=postgres://alaz:alaz@localhost:5435/alaz
QDRANT_URL=http://localhost:6334
OLLAMA_URL=http://localhost:11434
TEI_URL=http://localhost:8001
COLBERT_URL=http://localhost:8002

# LLM — any OpenAI-compatible endpoint (Ollama, Z.AI, OpenAI, LM Studio, vLLM, …)
#
# Ollama (local, default):
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen3:8b
#
# Z.AI (hosted GLM-4) — uncomment and replace the block above:
# LLM_API_KEY=your-z-ai-api-key
# LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# LLM_MODEL=glm-4.7
#
# Legacy ZHIPUAI_* names are still accepted as a fallback.

# Embedding
TEXT_EMBED_MODEL=qwen3-embedding:8b
TEXT_EMBED_DIM=4096

# Auth & Security
JWT_SECRET=generate-a-random-64-char-secret-here
VAULT_MASTER_KEY=generate-a-random-32-byte-hex-key-here

# Server
LISTEN_ADDR=0.0.0.0:3456
CORS_ORIGINS=http://localhost:3456
RUST_LOG=alaz=debug,tower_http=info,sqlx=warn

# Test database
TEST_DATABASE_URL=postgres://alaz:alaz@localhost:5435/alaz_test
